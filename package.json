{
  "name": "kite-app",
  "private": true,
  "version": "1.0.0",
  "description": "A high-performance multi-pane desktop shell for Zerodha Kite.",
  "author": "Sudhanya Dash",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint app",
    "preview": "vite preview",
    "build-win": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.kite.windows.app",
    "productName": "Kite Windows",
    "directories": {
      "output": "Release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "icon": "assets/icon.png",
      "target": {
        "target": "portable"
      }
    }
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "electron-store": "^11.0.2",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.27",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.1",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "main": "dist-electron/main.js"
}
